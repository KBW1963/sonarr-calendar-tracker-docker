<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ config.html_title }}</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,{{ sonarr_icon_base64 }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* (all existing styles remain unchanged) */
        :root {
            --primary-color: #00b4db;
            --primary-dark: #0083b0;
            --secondary-color: #1a1a2e;
            --background-color: #0f0f1e;
            --card-bg: #1a1a2e;
            --header-bg: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
            --text-color: #ffffff;
            --text-secondary: #aaaaaa;
            --border-color: #2d2d4d;
            --shadow-color: rgba(0,0,0,0.3);
            --progress-complete: #4CAF50;
            --progress-almost: #8BC34A;
            --progress-halfway: #FFC107;
            --progress-started: #FF9800;
            --progress-just-started: #FF5722;
            --progress-not-started: #F44336;
            --scrollbar-width: 6px;
            --episode-limit: {{ DISPLAY_EPISODES_LIMIT }};
            --episode-item-height: {{ EPISODE_ITEM_HEIGHT }}px;
            --expand-button-height: {{ EXPAND_BUTTON_HEIGHT }}px;
            --filter-bg: var(--card-bg);
            --stat-bg: #1a1a2e;
            --completed-section-bg: #1a1a2e;
            --legend-text-color: var(--text-color);
            --premiere-color: #00FF00;
            --season-finale-color: #FFA500;
            --series-finale-color: #FF0000;
            --midseason-premiere-color: #00CED1;
            --midseason-finale-color: #FF8C00;
            --series-premiere-color: #FFD700;
            --special-color: #9C27B0;
        }

        .theme-light {
            --background-color: #F5F5F5;
            --legend-text-color: #333333;
        }
        .theme-light footer {
            color: #000000;
        }
        .theme-light .last-updated,
        .theme-light .version-info,
        .theme-light .next-update {
            color: #000000;
        }

        .completed-seasons-section {
            background: var(--completed-section-bg) !important;
            padding: 25px;
            border-radius: 15px;
            margin: 30px 0;
            border: 1px solid var(--border-color);
        }
        .stat-progress {
            background: var(--stat-bg) !important;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 15px;
            border: 1px solid var(--border-color);
        }
        .completed-season-title,
        .completed-season-details,
        .completed-season-date,
        .stat-progress-header,
        .stat-progress-stats,
        .no-completed-seasons {
            color: var(--text-color) !important;
        }
        .no-completed-seasons {
            color: var(--text-secondary) !important;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html {
            scroll-behavior: smooth;
            -webkit-text-size-adjust: 100%;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
            background-color: var(--background-color);
            color: var(--text-color);
            min-height: 100vh;
            padding: 20px;
            line-height: 1.6;
            transition: background-color 0.3s ease;
            font-size: clamp(0.9rem, 2vw, 1rem);
        }
        .container {
            max-width: 1600px;
            margin: 0 auto;
            width: 100%;
            overflow-x: hidden;
        }
        .header-top {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 15px;
        }
        .theme-toggle {
            background: var(--card-bg);
            border: 2px solid var(--border-color);
            color: white;
            padding: 12px 16px;
            border-radius: 20px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            text-decoration: none;
            cursor: pointer;
            min-height: 44px;
            min-width: 44px;
        }
        .theme-toggle:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px var(--shadow-color);
        }
        .filter-dropdown {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--card-bg);
            padding: 5px 15px;
            border-radius: 20px;
            border: 2px solid var(--border-color);
        }
        .filter-dropdown i {
            color: var(--primary-color);
        }
        .show-filter {
            background: var(--card-bg);
            color: var(--text-color);
            border: 1px solid var(--border-color);
            padding: 12px 16px;
            border-radius: 15px;
            font-size: 0.95em;
            cursor: pointer;
            outline: none;
            min-width: 200px;
            min-height: 44px;
        }
        .show-filter:hover {
            border-color: var(--primary-color);
        }
        .show-filter option {
            background: var(--card-bg);
            color: var(--text-color);
        }
        .return-to-top {
            position: fixed;
            bottom: clamp(15px, 4vw, 30px);
            right: clamp(15px, 4vw, 30px);
            width: clamp(40px, 8vw, 50px);
            height: clamp(40px, 8vw, 50px);
            border-radius: 50%;
            background: var(--primary-color);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2em;
            box-shadow: 0 4px 15px rgba(0, 180, 219, 0.3);
            transition: all 0.3s ease;
            z-index: 1000;
            border: 2px solid var(--border-color);
            text-decoration: none;
            opacity: 0.9;
        }
        .return-to-top:hover {
            background: var(--primary-dark);
            transform: translateY(-5px);
            box-shadow: 0 6px 20px rgba(0, 180, 219, 0.4);
            opacity: 1;
        }
        header {
            margin-bottom: 40px;
            padding: 30px;
            background: var(--header-bg);
            border-radius: 15px;
            color: white;
            box-shadow: 0 10px 30px var(--shadow-color);
        }
        h1 {
            font-size: clamp(1.8rem, 6vw, 2.8rem);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }

        /* Library heading (styled like the date box) */
        .library-heading {
            background: rgba(255,255,255,0.1);
            padding: 10px 20px;
            border-radius: 10px;
            backdrop-filter: blur(10px);
            display: inline-block;
            margin: 0 auto 20px;
            font-size: clamp(1rem, 4vw, 1.4rem);
            color: white;
            /* display: flex; */
            align-items: center;
            gap: 8px;
            width: fit-content;
        }

        /* ---------- Summary Grid (Sentence Cards) ---------- */
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-bottom: 30px;
        }
        @media (min-width: 600px) {
            .summary-grid {
                grid-template-columns: repeat(4, 1fr);
            }
        }
        .summary-card {
            background: var(--stat-bg);
            padding: 20px;
            border-radius: 10px;
            text-align: left;  /* for sentence readability */
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            transition: transform 0.3s ease;
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-height: 120px;
        }
        .summary-card:hover {
            transform: translateY(-5px);
        }
        .summary-card p {
            margin: 0;
            font-size: 1.1em;
            line-height: 1.4;
            color: white;
        }
        .summary-card strong {
            color: var(--primary-color);
            font-size: 1.2em;
        }
        .summary-card .stat-number {
            font-size: 1.8em;
            font-weight: bold;
            color: white;
            display: inline;
        }

        .date-range {
            text-align: center;
            font-size: clamp(1rem, 4vw, 1.4rem);
            margin-bottom: 20px;
            background: rgba(255, 255, 255, 0.1);
            padding: 10px 20px;
            border-radius: 10px;
            display: inline-block;
            margin: 0 auto 20px;
            backdrop-filter: blur(10px);
        }

        .completed-seasons-section {
            background: var(--completed-section-bg);
            padding: 25px;
            border-radius: 15px;
            margin: 30px 0;
            border: 1px solid var(--border-color);
        }
        .section-title {
            font-size: 1.4em;
            font-weight: 600;
            margin-bottom: 20px;
            color: var(--primary-color);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .completed-seasons-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
        }
        .show-card-wrapper {
            display: block;
            scroll-margin-top: 20px;
            transition: all 0.3s ease;
        }
        .show-card-link {
            text-decoration: none;
            color: inherit;
            display: block;
        }
        .completed-season-link {
            text-decoration: none;
            color: inherit;
            display: block;
        }
        .completed-season-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px;
            background: var(--card-bg);
            border-radius: 10px;
            border: 1px solid var(--border-color);
            transition: transform 0.3s ease;
            cursor: pointer;
        }
        .completed-season-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px var(--shadow-color);
            border-color: var(--primary-color);
        }
        .completed-season-poster {
            width: 60px;
            height: 90px;
            border-radius: 5px;
            overflow: hidden;
            flex-shrink: 0;
            background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .completed-season-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            background: var(--card-bg);
        }
        .poster-placeholder-small {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5em;
            color: white;
        }
        .completed-season-info {
            flex-grow: 1;
        }
        .completed-season-title {
            font-weight: 600;
            margin-bottom: 5px;
            font-size: 1.1em;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: var(--text-color);
        }
        .completed-season-details {
            font-size: 0.9em;
            color: var(--text-secondary);
            margin-bottom: 5px;
        }
        .completed-season-date {
            font-size: 0.85em;
            color: var(--progress-complete);
            font-weight: 500;
        }
        .no-completed-seasons {
            text-align: center;
            padding: 40px;
            color: var(--text-secondary);
            font-style: italic;
            grid-column: 1 / -1;
        }

        /* ---------- Overall Progress Bars ---------- */
        .overall-progress-section {
            margin: 30px 0;
        }
        .stat-progress {
            background: var(--stat-bg);
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 15px;
            border: 1px solid var(--border-color);
        }
        .stat-progress-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-weight: 600;
            color: var(--text-color);
        }
        .stat-progress-bar {
            height: 20px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 8px;
        }
        .stat-progress-fill {
            height: 100%;
            border-radius: 10px;
            transition: width 1s ease-in-out;
        }
        .stat-progress-stats {
            font-size: 0.9em;
            color: var(--text-secondary);
        }

        /* Legend container (now inside filter bar) */
        .legend-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            padding: 15px 0 0;
            margin-top: 15px;
            border-top: 1px solid var(--border-color);
            width: 100%;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9em;
            color: var(--legend-text-color);
        }

        .legend-bar {
            width: 30px;
            height: 12px;
            border-radius: 6px;
        }

        /* Filter bar */
        .filter-bar {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin: 25px 0;
            padding: 15px;
            background: var(--filter-bg);
            border-radius: 12px;
            border: 1px solid var(--border-color);
            flex-direction: column;
        }

        .filter-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
            gap: 15px;
            width: 100%;
        }

        .filter-group {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--card-bg);
            padding: 5px 15px;
            border-radius: 20px;
            border: 2px solid var(--border-color);
        }

        .filter-group i {
            color: var(--primary-color);
        }

        .filter-group input,
        .filter-group select {
            background: transparent;
            border: none;
            color: var(--text-color);
            outline: none;
            padding: 8px 0;
            font-size: 0.95em;
        }

        .filter-group input {
            width: 180px;
        }

        .filter-group select {
            cursor: pointer;
            min-width: 180px;
        }

        .filter-group select option {
            background: var(--card-bg);
            color: var(--text-color);
        }

        .clear-btn {
            background: var(--primary-color);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: 600;
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

        .clear-btn:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
        }

        .shows-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 15px;
            margin-bottom: 40px;
        }
        .show-card {
            background: var(--card-bg);
            border-radius: 15px;
            overflow: hidden;
            transition: all 0.3s ease;
            border: 1px solid var(--border-color);
            box-shadow: 0 5px 15px var(--shadow-color);
            display: flex;
            flex-direction: column;
            height: 100%;
            min-width: 0;
        }
        .show-card-link:hover .show-card {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px var(--shadow-color);
            border-color: var(--primary-color);
        }
        .card-header {
            position: relative;
            height: auto;
            aspect-ratio: 16 / 9;
            max-height: 250px;
            overflow: hidden;
            flex-shrink: 0;
            background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
            width: 100%;
        }
        .poster-container {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        }
        .card-poster {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
            transition: transform 0.5s ease;
            max-width: 100%;
        }
        .show-card-link:hover .card-poster {
            transform: scale(1.05);
        }
        .poster-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
            padding: 20px;
            text-align: center;
        }
        .placeholder-icon {
            font-size: 4em;
            margin-bottom: 15px;
        }
        .placeholder-title {
            font-size: 1.2em;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 90%;
        }
        .show-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            padding: 6px 12px;
            border-radius: 15px;
            font-weight: bold;
            font-size: 0.9em;
            backdrop-filter: blur(5px);
            z-index: 10;
        }
        .status-overall {
            position: absolute;
            top: 15px;
            left: 15px;
            width: 27px;
            height: 27px;
            border-radius: 50%;
            box-shadow: 0 0 10px currentColor;
            z-index: 10;
            transition: transform 0.2s ease;
        }
        .status-overall:hover {
            transform: scale(1.1);
        }
        .card-content {
            padding: clamp(10px, 3vw, 20px);
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
            width: 100%;
        }
        .title-container {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 5px;
            min-width: 0;
            overflow: hidden;
            width: 100%;
        }
        .show-title {
            font-size: clamp(1rem, 3.5vw, 1.3rem);
            color: var(--text-color);
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            flex: 1;
            min-width: 0;
            max-width: 100%;
            overflow-wrap: break-word;
            word-break: break-word;
        }
        .season-complete-badge-inline {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--progress-complete);
            color: white;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            font-weight: bold;
            font-size: 0.9em;
            box-shadow: 0 0 10px var(--progress-complete);
            flex-shrink: 0;
        }
        .show-meta {
            color: var(--primary-color);
            font-size: 0.9em;
            margin-bottom: 20px;
            min-height: 1.5em;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            min-width: 0;
        }
        .episodes-section {
            margin-bottom: 20px;
            flex-grow: 1;
            min-width: 0;
        }
        .episodes-section .section-title {
            font-size: 0.95em;
            margin-bottom: 10px;
            color: var(--text-secondary);
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 5px;
        }
        .episodes-list {
            overflow-y: hidden; /* no scroll when collapsed */
            padding-right: 5px;
            -webkit-overflow-scrolling: touch;
            transition: max-height 0.3s ease;
            min-height: calc(var(--episode-item-height) * var(--episode-limit) + var(--expand-button-height) + 40px);
            max-height: calc(var(--episode-item-height) * var(--episode-limit) + var(--expand-button-height) + 40px);
        }
        .episodes-list.expanded {
            overflow-y: auto;
            max-height: 400px;
        }
        .episodes-list::-webkit-scrollbar {
            width: var(--scrollbar-width);
        }
        .episodes-list::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 3px;
        }
        .episodes-list::-webkit-scrollbar-thumb {
            background: var(--primary-color);
            border-radius: 3px;
        }
        .episodes-list::-webkit-scrollbar-thumb:hover {
            background: var(--primary-dark);
        }
        .episodes-list {
            scrollbar-width: thin;
            scrollbar-color: var(--primary-color) rgba(255, 255, 255, 0.05);
        }
        .episode-item {
            padding: 8px 10px;
            margin-bottom: 8px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 8px;
            border-left: 4px solid;
            transition: transform 0.2s ease, opacity 0.3s ease;
            height: var(--episode-item-height);
            position: relative;
        }
        .episode-item:hover {
            transform: translateX(5px);
        }
        .episode-item.status-downloaded {
            border-left-color: var(--progress-complete);
        }
        .episode-item.status-monitored {
            border-left-color: var(--progress-halfway);
        }
        .episode-item.status-missing {
            border-left-color: var(--progress-not-started);
        }
        .episode-item.episode-special {
            border-left-color: var(--special-color) !important;
        }
        .episode-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 2px 6px;
            border-radius: 12px;
            font-size: 0.7em;
            font-weight: 600;
            vertical-align: middle;
            white-space: nowrap;
            max-width: 120px;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-left: auto;
            margin-right: 0;
        }
        .episode-badge i {
            font-size: 0.8em;
        }
        .episode-badge.premiere {
            background: var(--premiere-color)20;
            color: var(--premiere-color);
            border: 1px solid var(--premiere-color)40;
        }
        .episode-badge.season-finale {
            background: var(--season-finale-color)20;
            color: var(--season-finale-color);
            border: 1px solid var(--season-finale-color)40;
        }
        .episode-badge.series-finale {
            background: var(--series-finale-color)20;
            color: var(--series-finale-color);
            border: 1px solid var(--series-finale-color)40;
        }
        .episode-badge.midseason-premiere {
            background: var(--midseason-premiere-color)20;
            color: var(--midseason-premiere-color);
            border: 1px solid var(--midseason-premiere-color)40;
        }
        .episode-badge.midseason-finale {
            background: var(--midseason-finale-color)20;
            color: var(--midseason-finale-color);
            border: 1px solid var(--midseason-finale-color)40;
        }
        .episode-badge.series-premiere {
            background: var(--series-premiere-color)20;
            color: var(--series-premiere-color);
            border: 1px solid var(--series-premiere-color)40;
        }
        .episode-badge.special {
            background: var(--special-color)20;
            color: var(--special-color);
            border: 1px solid var(--special-color)40;
        }
        .episode-item.padding-item {
            background: rgba(255, 255, 255, 0.03);
            border-left-color: transparent;
            cursor: default;
            animation: none;
            border: 1px dashed var(--border-color);
            opacity: 0.35;
        }
        .episode-item.padding-item:hover {
            transform: none;
            background: rgba(255, 255, 255, 0.03);
        }
        .episode-item.padding-item .episode-number,
        .episode-item.padding-item .episode-date,
        .episode-item.padding-item .episode-days,
        .episode-item.padding-item .episode-title {
            color: var(--text-secondary);
            opacity: 0.6;
        }
        .episode-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 4px;
            font-size: 0.85em;
            align-items: center;
            flex-wrap: wrap;
            gap: 4px;
        }
        .episode-header .episode-badge {
            display: none;
        }
        .episode-number {
            font-weight: bold;
            color: var(--primary-color);
            white-space: nowrap;
            min-width: 0;
            flex-shrink: 1;
        }
        .episode-date {
            color: var(--text-secondary);
            white-space: nowrap;
            min-width: 0;
            flex-shrink: 1;
        }
        .episode-days {
            font-weight: 600;
            white-space: nowrap;
            min-width: 0;
            flex-shrink: 1;
        }
        .days-today {
            color: var(--progress-complete);
        }
        .days-tomorrow {
            color: var(--progress-almost);
        }
        .days-future {
            color: var(--progress-started);
        }
        .days-past {
            color: var(--text-secondary);
            opacity: 0.7;
        }
        .days-yesterday {
            color: var(--progress-just-started);
        }
        .episode-title {
            font-size: clamp(0.8rem, 3vw, 0.95rem);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: var(--text-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 4px;
        }
        .episode-title .episode-badge {
            display: inline-flex;
            margin-left: auto;
        }
        .episode-multiple .episode-titles {
            font-size: 0.9em;
            color: var(--text-secondary);
            font-style: italic;
            margin-top: 4px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 4px;
        }
        .expand-episodes-btn {
            width: 100%;
            padding: 12px 16px;
            margin-top: 10px;
            margin-bottom: 0;
            background: rgba(0, 180, 219, 0.1);
            border: 1px solid var(--primary-color);
            color: var(--primary-color);
            border-radius: 20px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85em;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s ease;
            height: var(--expand-button-height);
            min-height: 44px;
            box-sizing: border-box;
        }
        .expand-episodes-btn:hover {
            background: rgba(0, 180, 219, 0.2);
            transform: translateY(-2px);
        }
        .expand-episodes-btn i {
            transition: transform 0.3s ease;
        }
        .expand-episodes-btn.expanded i {
            transform: rotate(180deg);
        }
        .all-episodes-container {
            animation: slideDown 0.3s ease-out;
        }
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .no-episodes {
            text-align: center;
            color: var(--text-secondary);
            font-style: italic;
            padding: 20px;
            font-size: 0.9em;
        }
        .progress-section {
            margin: 15px 0;
            min-width: 0;
        }
        .progress-item {
            margin-bottom: 15px;
        }
        .progress-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 6px;
            font-weight: 600;
            font-size: 0.9em;
            color: var(--text-color);
        }
        .progress-bar {
            height: 10px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 5px;
            overflow: hidden;
            margin-bottom: 6px;
        }
        .progress-fill {
            height: 100%;
            border-radius: 5px;
            transition: width 0.5s ease;
        }
        .progress-stats {
            font-size: 0.8em;
            color: var(--text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .genres {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            margin: 15px 0;
            min-width: 0;
        }
        .genre-tag {
            background: rgba(0, 180, 219, 0.1);
            color: var(--primary-color);
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 0.8em;
            font-weight: 500;
        }
        .show-footer {
            margin-top: auto;
            padding-top: 15px;
            border-top: 1px solid var(--border-color);
            font-size: 0.85em;
            color: var(--text-secondary);
            min-width: 0;
        }
        .season-info {
            display: flex;
            justify-content: space-between;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .monitored-count {
            color: var(--progress-complete);
        }
        .unmonitored-count {
            color: var(--progress-started);
        }
        footer {
            text-align: center;
            padding: 30px;
            color: var(--text-secondary);
            font-size: 0.9em;
            border-top: 1px solid var(--border-color);
            margin-top: 40px;
        }
        .last-updated {
            margin-top: 10px;
            font-size: 0.9em;
            opacity: 0.7;
            color: var(--text-secondary);
        }
        .version-info {
            margin-top: 5px;
            font-size: 0.85em;
            opacity: 0.6;
            color: var(--text-secondary);
        }
        .next-update {
            margin-top: 5px;
            font-size: 0.85em;
            opacity: 0.6;
            color: var(--text-secondary);
        }
        .refresh-btn {
            background: var(--primary-color);
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 25px;
            cursor: pointer;
            font-weight: 600;
            margin-top: 15px;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            min-height: 44px;
        }
        .refresh-btn:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .show-card {
            animation: fadeIn 0.5s ease-out;
        }
        .loading {
            display: none;
            text-align: center;
            padding: 40px;
            color: var(--primary-color);
        }
        .spinner {
            border: 3px solid var(--border-color);
            border-top: 3px solid var(--primary-color);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        img {
            max-width: 100%;
            height: auto;
        }
    </style>
</head>
<body class="theme-{{ config.html_theme }}">
    <div class="container">
        <div class="header-top">
            <div class="filter-dropdown">
                <i class="fas fa-search"></i>
                <select id="showFilter" class="show-filter" onchange="window.location.href=this.value">
                    <option value="#all" selected>All Shows</option>
                    {% for show in shows %}
                    <option value="#show-{{ show.series_id }}">{{ show.title|truncate(30) }}</option>
                    {% endfor %}
                </select>
            </div>
            <button id="themeToggle" class="theme-toggle">
                <i class="fas fa-moon" id="themeIcon"></i>
                <span id="themeText">Switch to Light</span>
            </button>
        </div>

        <a href="#" class="return-to-top" title="Return to top">
            <i class="fas fa-arrow-up"></i>
        </a>

        <header>
            <h1><i class="fas fa-tv"></i> Upcoming TV Shows</h1>

            <!-- Library heading -->
            <div class="library-heading">
                <i class="fas fa-book-open"></i> Your current library overview
            </div>

            <!-- First row: library stats -->
            <div class="summary-grid">
                <!-- Card 1: Shows & downloaded -->
                <div class="summary-card">
                    <p>
                        You have <strong>{{ library_stats.total_series|default(0) }}</strong> shows,
                        which have <strong>{{ library_stats.total_downloaded_all|default(0) }}</strong> episodes downloaded.
                    </p>
                </div>
                <!-- Card 2: Missing monitored -->
                <div class="summary-card">
                    {% if library_stats.missing_monitored == 0 %}
                        <p>There are currently no missing monitored episodes.</p>
                    {% else %}
                        <p>
                            You have <strong>{{ library_stats.missing_monitored }}</strong> missing episodes
                            for shows that are monitored.
                        </p>
                    {% endif %}
                </div>
                <!-- Card 3: Continuing vs Ended vs Upcoming -->
                <div class="summary-card">
                    <p>
                        Out of <strong>{{ library_stats.total_series|default(0) }}</strong> shows in your library,
                        there are <strong>{{ library_stats.continuing_series|default(0) }}</strong> continuing,
                        <strong>{{ library_stats.ended_series|default(0) }}</strong> ended,
                        and <strong>{{ library_stats.upcoming_series|default(0) }}</strong> upcoming.
                    </p>
                </div>
                <!-- Card 4: Future episodes -->
                <div class="summary-card">
                    <p>
                        Sonarr has <strong>{{ library_stats.future_episodes|default(0) }}</strong> future episodes scheduled.
                    </p>
                </div>
            </div>

            <!-- Date range (between the two rows) -->
            <div class="date-range">
                <i class="fas fa-calendar-alt"></i> Date Range: {{ date_range.start|format_date }} to {{ date_range.end|format_date }}
                ({{ date_range.total_days }} days total)
            </div>

            <!-- Second row: range stats (only two cards) -->
            <div class="summary-grid" style="margin-top: 10px;">
                <!-- Card 1: shows with episodes in range -->
                <div class="summary-card">
                    <p>
                        There are <strong>{{ range_stats.shows_with_episodes }}</strong> shows with episodes in set date range.
                    </p>
                </div>
                <!-- Card 2: episodes in range with downloaded count -->
                <div class="summary-card">
                    <p>
                        <strong>{{ range_stats.episodes_in_range }}</strong> episodes in set date range with
                        <strong>{{ range_stats.downloaded_in_range }}</strong> episodes already downloaded.
                    </p>
                </div>
            </div>
        </header>

        <div class="completed-seasons-section">
            <div class="section-title">
                <i class="fas fa-trophy"></i>
                <span>Recently Completed Seasons ({{ completed_seasons|length }})</span>
            </div>
            <div class="completed-seasons-grid">
                {% if completed_seasons %}
                    {% for cs in completed_seasons %}
                    <a href="{{ config.sonarr_url }}/series/{{ cs.title|slugify }}" target="_blank" class="completed-season-link">
                        <div class="completed-season-item">
                            <div class="completed-season-poster">
                                {% if cs.poster_url %}
                                <img src="{{ cs.poster_url }}" alt="{{ cs.title }}" loading="lazy" class="completed-season-img">
                                {% else %}
                                <div class="poster-placeholder-small">🎬</div>
                                {% endif %}
                            </div>
                            <div class="completed-season-info">
                                <div class="completed-season-title" title="{{ cs.title }}">{{ cs.title|truncate(30) }}</div>
                                <div class="completed-season-details">Season {{ cs.season }} • {{ cs.total_episodes }} episodes</div>
                                <div class="completed-season-date">Completed: {{ cs.completion_date|format_date }}</div>
                            </div>
                        </div>
                    </a>
                    {% endfor %}
                {% else %}
                <div class="no-completed-seasons">No seasons completed in date range</div>
                {% endif %}
            </div>
        </div>

        <!-- ========== Overall progress bars ========== -->
        <div class="overall-progress-section">
            <div class="stat-progress">
                <div class="stat-progress-header">
                    <span>Complete Library Progress</span>
                    <span class="stat-progress-percentage">{{ "%.1f"|format(library_stats.overall_progress) }}%</span>
                </div>
                <div class="stat-progress-bar">
                    <div class="stat-progress-fill" style="width: {{ library_stats.overall_progress }}%; 
                         background: {{ get_progress_bar_color(library_stats.overall_progress) }};"></div>
                </div>
                <div class="stat-progress-stats">
                    {{ library_stats.total_downloaded_all }}/{{ library_stats.total_episodes_all }} episodes • 
                    {{ library_stats.total_series }} shows
                </div>
                <!-- Footnote moved here -->
                <div style="margin-top: 15px; font-size: 0.9em; opacity: 0.9; text-align: center; border-top: 1px solid var(--border-color); padding-top: 10px;">
                    * Overall progress includes all episodes, whether monitored or not.
                </div>
            </div>

            <div class="stat-progress">
                <div class="stat-progress-header">
                    <span>Date Range Progress ({{ date_range.start|format_date }} to {{ date_range.end|format_date }})</span>
                    <span class="stat-progress-percentage">{{ "%.1f"|format(range_stats.overall_date_range_progress) }}%</span>
                </div>
                <div class="stat-progress-bar">
                    <div class="stat-progress-fill" style="width: {{ range_stats.overall_date_range_progress }}%; 
                         background: {{ get_progress_bar_color(range_stats.overall_date_range_progress) }};"></div>
                </div>
                <div class="stat-progress-stats">
                    {{ range_stats.downloaded_in_range }}/{{ range_stats.episodes_in_range }} episodes in date range
                </div>
            </div>
        </div>

        <!-- Unified Filter Bar (with integrated legend) -->
        <div class="filter-bar">
            <div class="filter-row">
                <!-- Search by title -->
                <div class="filter-group">
                    <i class="fas fa-search"></i>
                    <input type="text" id="titleSearch" placeholder="Search shows...">
                </div>

                <!-- Progress filter dropdown (UPDATED with range_stats counts) -->
                <div class="filter-group">
                    <i class="fas fa-chart-line"></i>
                    <select id="progressFilter">
                        <option value="all" selected>All Shows ({{ range_stats.total_series }} in range)</option>
                        <option value="complete">Season Complete ({{ range_stats.shows_complete }})</option>
                        <option value="high">Overall Progress 75‑99% ({{ range_stats.shows_high_progress }})</option>
                        <option value="medium">Overall Progress 25‑74% ({{ range_stats.shows_medium_progress }})</option>
                        <option value="low">Overall Progress <25% ({{ range_stats.shows_low_progress + range_stats.shows_not_started }})</option>
                        <option value="date-high">Date Range Progress ≥75%</option>
                        <option value="date-low">Date Range Progress <25% (including 0%)</option>
                        <option value="has-episodes">Has Episodes in Range ({{ range_stats.shows_with_episodes }})</option>
                    </select>
                </div>

                <!-- Jump to show dropdown -->
                <div class="filter-group">
                    <i class="fas fa-film"></i>
                    <select id="jumpToShow" class="show-filter" onchange="window.location.href=this.value">
                        <option value="#all" selected>Jump to show…</option>
                        {% for show in shows %}
                        <option value="#show-{{ show.series_id }}">{{ show.title|truncate(30) }}</option>
                        {% endfor %}
                    </select>
                </div>

                <!-- Clear Filters button -->
                <button id="clearFilters" class="clear-btn">
                    <i class="fas fa-times"></i> Clear Filters
                </button>
            </div>

            <!-- Legend container inside filter bar as footer -->
            <div class="legend-container">
                <div class="legend-item" title="All episodes downloaded">
                    <div class="legend-bar" style="background: var(--progress-complete);"></div>
                    <span>Complete (100%)</span>
                </div>
                <div class="legend-item" title="75‑99% downloaded">
                    <div class="legend-bar" style="background: var(--progress-almost);"></div>
                    <span>Almost Complete (75‑99%)</span>
                </div>
                <div class="legend-item" title="50‑74% downloaded">
                    <div class="legend-bar" style="background: var(--progress-halfway);"></div>
                    <span>Halfway (50‑74%)</span>
                </div>
                <div class="legend-item" title="25‑49% downloaded">
                    <div class="legend-bar" style="background: var(--progress-started);"></div>
                    <span>Started (25‑49%)</span>
                </div>
                <div class="legend-item" title="1‑24% downloaded">
                    <div class="legend-bar" style="background: var(--progress-just-started);"></div>
                    <span>Just Started (1‑24%)</span>
                </div>
                <div class="legend-item" title="No episodes downloaded">
                    <div class="legend-bar" style="background: var(--progress-not-started);"></div>
                    <span>Not Started (0%)</span>
                </div>
            </div>
        </div>

        <div class="shows-grid" id="showsGrid">
            {% if shows %}
                {% for show in shows %}
                <div id="show-{{ show.series_id }}" class="show-card-wrapper" data-show-id="{{ show.series_id }}">
                    <a href="{{ config.sonarr_url }}/series/{{ show.title|slugify }}" target="_blank" class="show-card-link">
                        <div class="show-card" 
                             data-progress="{{ show.progress_percentage }}" 
                             data-date-range-progress="{{ show.date_range_percentage }}"
                             data-has-episodes="{{ 'true' if show.date_range_episodes > 0 else 'false' }}"
                             data-season-complete="{{ 'true' if show.current_season_complete else 'false' }}">
                            <div class="card-header">
                                {% if show.poster_url %}
                                <div class="poster-container">
                                    <img src="{{ show.poster_url }}" alt="{{ show.title }}" class="card-poster" loading="lazy">
                                </div>
                                {% else %}
                                <div class="poster-container">
                                    <div class="poster-placeholder" style="background: {{ show.progress_color }}">
                                        <span class="placeholder-icon">🎬</span>
                                        <div class="placeholder-title">{{ show.title|truncate(30) }}</div>
                                    </div>
                                </div>
                                {% endif %}
                                <div class="show-badge" title="Current Season">S{{ "%02d"|format(show.current_season) }}</div>
                                <!-- Dot color now uses date_range_color -->
                                <div class="status-overall" style="background: {{ show.date_range_color }}; width: 27px; height: 27px;" 
                                     title="Date Range Progress: {{ "%.1f"|format(show.date_range_percentage) }}%"></div>
                            </div>
                            <div class="card-content">
                                <div class="title-container">
                                    <h3 class="show-title" title="{{ show.title }}">{{ show.title|truncate(30) }}</h3>
                                    {% if show.current_season_complete %}
                                    <span class="season-complete-badge-inline" title="Season {{ show.current_season }} Complete">✓</span>
                                    {% endif %}
                                </div>
                                <div class="show-meta">
                                    {{ show.year if show.year else '' }}
                                    {{ ' • ' + show.network if show.network else '' }}
                                    {{ ' • ' + show.runtime|string + ' min' if show.runtime else '' }}
                                    {{ ' • ⭐ ' + "%.1f"|format(show.rating) if show.rating > 0 else '' }}
                                </div>

                                <div class="episodes-section">
                                    <div class="section-title">Episodes in Date Range</div>
                                    <div class="episodes-list" id="episodes-list-{{ show.series_id }}">
                                        {# Preview episodes (first DISPLAY_EPISODES_LIMIT) #}
                                        {% for ep in show.episodes_in_range[:DISPLAY_EPISODES_LIMIT] %}
                                            {% set status_class = 'status-downloaded' if ep.has_file else ('status-monitored' if ep.monitored else 'status-missing') %}
                                            {% set badge = get_episode_badge(ep, show.season_episode_counts) %}
                                            {% set extra_class = 'episode-special' if badge and badge.type == 'special' else '' %}
                                            {% if ep.single_episode %}
                                            <div class="episode-item {{ status_class }} {{ extra_class }} preview-episode" title="{{ ep.full_title }}">
                                                <div class="episode-header">
                                                    <span class="episode-number">{{ ep.formatted_season_episode }}</span>
                                                    <span class="episode-date">{{ ep.air_date|format_date }}</span>
                                                    <span class="episode-days {{ get_days_class(ep.days_until) }}">{{ get_days_text(ep.days_until) }}</span>
                                                </div>
                                                <div class="episode-title">
                                                    <span>{{ ep.title|truncate(25) }}</span>
                                                    {% if badge %}
                                                    <span class="episode-badge {{ badge.type }}" style="background: {{ badge.color }}20; color: {{ badge.color }}; border: 1px solid {{ badge.color }}40;" title="{{ badge.text }}">
                                                        <i class="fas {{ badge.icon }}"></i> {{ badge.text }}
                                                    </span>
                                                    {% endif %}
                                                </div>
                                            </div>
                                            {% else %}
                                            <div class="episode-item {{ status_class }} {{ extra_class }} episode-multiple preview-episode" title="{{ ep.full_tooltip }}">
                                                <div class="episode-header">
                                                    <span class="episode-number">{{ ep.formatted_season_episode }}</span>
                                                    <span class="episode-date">{{ ep.air_date|format_date }}</span>
                                                    <span class="episode-days {{ get_days_class(ep.days_until) }}">{{ get_days_text(ep.days_until) }}</span>
                                                </div>
                                                <div class="episode-titles">
                                                    {{ ep.titles_display }} ({{ ep.individual_episode_count }} eps)
                                                    {% if badge %}
                                                    <span class="episode-badge {{ badge.type }}" style="background: {{ badge.color }}20; color: {{ badge.color }}; border: 1px solid {{ badge.color }}40;" title="{{ badge.text }}">
                                                        <i class="fas {{ badge.icon }}"></i> {{ badge.text }}
                                                    </span>
                                                    {% endif %}
                                                </div>
                                            </div>
                                            {% endif %}
                                        {% endfor %}

                                        {# If there are more episodes, add expand button #}
                                        {% if show.episodes_in_range|length > DISPLAY_EPISODES_LIMIT %}
                                        <button class="expand-episodes-btn" data-show-id="{{ show.series_id }}" data-show-index="{{ loop.index0 }}">
                                            <i class="fas fa-chevron-down"></i> Show More Episodes
                                        </button>

                                        {# Hidden container for additional episodes #}
                                        <div class="all-episodes-container" id="all-episodes-{{ show.series_id }}" style="display: none;">
                                            {% for ep in show.episodes_in_range[DISPLAY_EPISODES_LIMIT:] %}
                                                {% set status_class = 'status-downloaded' if ep.has_file else ('status-monitored' if ep.monitored else 'status-missing') %}
                                                {% set badge = get_episode_badge(ep, show.season_episode_counts) %}
                                                {% set extra_class = 'episode-special' if badge and badge.type == 'special' else '' %}
                                                {% if ep.single_episode %}
                                                <div class="episode-item {{ status_class }} {{ extra_class }}" title="{{ ep.full_title }}">
                                                    <div class="episode-header">
                                                        <span class="episode-number">{{ ep.formatted_season_episode }}</span>
                                                        <span class="episode-date">{{ ep.air_date|format_date }}</span>
                                                        <span class="episode-days {{ get_days_class(ep.days_until) }}">{{ get_days_text(ep.days_until) }}</span>
                                                    </div>
                                                    <div class="episode-title">
                                                        <span>{{ ep.title|truncate(25) }}</span>
                                                        {% if badge %}
                                                        <span class="episode-badge {{ badge.type }}" style="background: {{ badge.color }}20; color: {{ badge.color }}; border: 1px solid {{ badge.color }}40;" title="{{ badge.text }}">
                                                            <i class="fas {{ badge.icon }}"></i> {{ badge.text }}
                                                        </span>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                                {% else %}
                                                <div class="episode-item {{ status_class }} {{ extra_class }} episode-multiple" title="{{ ep.full_tooltip }}">
                                                    <div class="episode-header">
                                                        <span class="episode-number">{{ ep.formatted_season_episode }}</span>
                                                        <span class="episode-date">{{ ep.air_date|format_date }}</span>
                                                        <span class="episode-days {{ get_days_class(ep.days_until) }}">{{ get_days_text(ep.days_until) }}</span>
                                                    </div>
                                                    <div class="episode-titles">
                                                        {{ ep.titles_display }} ({{ ep.individual_episode_count }} eps)
                                                        {% if badge %}
                                                        <span class="episode-badge {{ badge.type }}" style="background: {{ badge.color }}20; color: {{ badge.color }}; border: 1px solid {{ badge.color }}40;" title="{{ badge.text }}">
                                                            <i class="fas {{ badge.icon }}"></i> {{ badge.text }}
                                                        </span>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                        {% endif %}

                                        {# Padding items for uniform height #}
                                        {% set preview_count = show.episodes_in_range[:DISPLAY_EPISODES_LIMIT]|length %}
                                        {% if preview_count < DISPLAY_EPISODES_LIMIT %}
                                            {% for i in range(DISPLAY_EPISODES_LIMIT - preview_count) %}
                                            <div class="episode-item padding-item" style="opacity: 0.35; pointer-events: none;">
                                                <div class="episode-header">
                                                    <span class="episode-number"> </span>
                                                    <span class="episode-date"> </span>
                                                    <span class="episode-days"> </span>
                                                </div>
                                                <div class="episode-title"> </div>
                                            </div>
                                            {% endfor %}
                                            <div class="episode-item padding-item" style="opacity: 0.4; height: {{ EXPAND_BUTTON_HEIGHT }}px; margin-top: 10px; display: flex; align-items: center; justify-content: center; border: 1px dashed var(--border-color);">
                                                <span style="font-size: 0.85em; color: var(--text-secondary);">Current episodes in Date Range</span>
                                            </div>
                                        {% elif preview_count == DISPLAY_EPISODES_LIMIT and show.episodes_in_range|length == DISPLAY_EPISODES_LIMIT %}
                                            <div class="episode-item padding-item" style="opacity: 0.4; height: {{ EXPAND_BUTTON_HEIGHT }}px; margin-top: 10px; display: flex; align-items: center; justify-content: center; border: 1px dashed var(--border-color);">
                                                <span style="font-size: 0.85em; color: var(--text-secondary);">Current episodes in Date Range</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="progress-section">
                                    <div class="progress-item">
                                        <div class="progress-header">
                                            <span>Overall Progress</span>
                                            <span class="progress-percentage">{{ "%.1f"|format(show.progress_percentage) }}%</span>
                                        </div>
                                        <div class="progress-bar">
                                            <div class="progress-fill" style="width: {{ show.progress_percentage }}%; background: {{ show.progress_color }};"></div>
                                        </div>
                                        <div class="progress-stats">
                                            {{ show.downloaded_episodes }}/{{ show.total_episodes }} episodes • 
                                            Season {{ show.current_season }}: {{ "%.0f"|format(show.current_season_progress) }}%
                                        </div>
                                    </div>

                                    <div class="progress-item">
                                        <div class="progress-header">
                                            <span>Date Range Progress</span>
                                            <span class="progress-percentage">{{ "%.1f"|format(show.date_range_percentage) }}%</span>
                                        </div>
                                        <div class="progress-bar">
                                            <div class="progress-fill" style="width: {{ show.date_range_percentage }}%; background: {{ show.date_range_color }};"></div>
                                        </div>
                                        <div class="progress-stats">
                                            {{ show.date_range_downloaded }}/{{ show.date_range_episodes }} episodes in date range
                                        </div>
                                    </div>
                                </div>

                                {% if show.genres %}
                                <div class="genres">
                                    {% for genre in show.genres[:3] %}
                                    <span class="genre-tag">{{ genre }}</span>
                                    {% endfor %}
                                </div>
                                {% endif %}

                                <div class="show-footer">
                                    <div class="season-info">
                                        <span class="seasons-count">{{ show.total_seasons }} seasons</span>
                                        <span class="monitored-count">{{ show.monitored_seasons }} monitored</span>
                                        <span class="unmonitored-count">{{ show.unmonitored_seasons }} unmonitored*</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                {% endfor %}
            {% else %}
                <div class="empty-state" style="grid-column: 1 / -1; text-align: center; padding: 60px 20px;">
                    <div style="font-size: 4em; margin-bottom: 20px;">📺</div>
                    <h3 style="font-size: 1.8em; margin-bottom: 15px; color: var(--text-color);">No Shows with Episodes in Date Range</h3>
                    <p style="font-size: 1.2em; color: var(--text-secondary); margin-bottom: 10px;">
                        No shows have episodes scheduled from {{ date_range.start|format_date }} to {{ date_range.end|format_date }}.
                    </p>
                    <p style="font-size: 1em; color: var(--text-secondary);">
                        Try adjusting your date range in the configuration.
                    </p>
                </div>
            {% endif %}
        </div>

        <div class="loading" id="loadingIndicator">
            <div class="spinner"></div>
            <div>Updating calendar...</div>
        </div>

        <footer>
            <div>Powered by <a href="https://sonarr.tv/" target="_blank" rel="noopener noreferrer">Sonarr</a></div>
            <div class="last-updated" id="lastUpdated">
                Last updated: {{ now()|format_date }} {{ now().strftime('%H:%M:%S UTC') }}
            </div>
            <div class="next-update">
                Next update: {{ (now() + timedelta(hours=config.refresh_interval_hours)) | format_date }}
                at {{ (now() + timedelta(hours=config.refresh_interval_hours)).strftime('%I:%M %p').lstrip('0') }}
            </div>
            <div class="version-info">Version {{ version }}</div>
            <a href="#" class="refresh-btn" onclick="location.reload()">
                <i class="fas fa-sync-alt"></i> Refresh Now
            </a>
        </footer>
    </div>

    <script>
        // Track expanded state per card
        let expandedCards = new Set();

        function setupExpandButtons() {
            document.querySelectorAll('.expand-episodes-btn').forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const showId = this.dataset.showId;
                    const allEpisodesContainer = document.getElementById(`all-episodes-${showId}`);
                    const episodesList = document.getElementById(`episodes-list-${showId}`);

                    if (allEpisodesContainer.style.display === 'none') {
                        allEpisodesContainer.style.display = 'block';
                        this.innerHTML = '<i class="fas fa-chevron-up"></i> Show Less';
                        this.classList.add('expanded');
                        episodesList.classList.add('expanded');
                        expandedCards.add(showId);
                    } else {
                        allEpisodesContainer.style.display = 'none';
                        this.innerHTML = '<i class="fas fa-chevron-down"></i> Show More Episodes';
                        this.classList.remove('expanded');
                        episodesList.classList.remove('expanded');
                        expandedCards.delete(showId);
                    }
                });
            });
        }

        function setupMouseLeaveHandlers() {
            document.querySelectorAll('.show-card-wrapper').forEach(wrapper => {
                wrapper.addEventListener('mouseleave', function() {
                    const showId = this.dataset.showId;
                    if (expandedCards.has(showId)) {
                        const allEpisodesContainer = document.getElementById(`all-episodes-${showId}`);
                        const episodesList = document.getElementById(`episodes-list-${showId}`);
                        const expandButton = this.querySelector('.expand-episodes-btn');
                        if (allEpisodesContainer && expandButton) {
                            allEpisodesContainer.style.display = 'none';
                            expandButton.innerHTML = '<i class="fas fa-chevron-down"></i> Show More Episodes';
                            expandButton.classList.remove('expanded');
                            episodesList.classList.remove('expanded');
                            expandedCards.delete(showId);
                        }
                    }
                });
            });
        }

        function updateThemeButton(theme) {
            const themeIcon = document.getElementById('themeIcon');
            const themeText = document.getElementById('themeText');
            if (theme === 'light') {
                themeIcon.className = 'fas fa-sun';
                themeText.textContent = 'Switch to Dark';
            } else {
                themeIcon.className = 'fas fa-moon';
                themeText.textContent = 'Switch to Light';
            }
        }

        // Combined filter function (search + progress)
        function applyFilters() {
            const searchTerm = document.getElementById('titleSearch').value.toLowerCase();
            const progressFilter = document.getElementById('progressFilter').value;

            document.querySelectorAll('.show-card-wrapper').forEach(wrapper => {
                const card = wrapper.querySelector('.show-card');
                if (!card) return;

                // Search filter
                const title = wrapper.querySelector('.show-title')?.textContent.toLowerCase() || '';
                const matchesSearch = title.includes(searchTerm);

                // Progress filter
                let matchesProgress = true;
                if (progressFilter !== 'all') {
                    const progress = parseFloat(card.dataset.progress);
                    const dateRangeProgress = parseFloat(card.dataset.dateRangeProgress);
                    const hasEpisodes = card.dataset.hasEpisodes === 'true';
                    const seasonComplete = card.dataset.seasonComplete === 'true';

                    switch (progressFilter) {
                        case 'complete':
                            matchesProgress = seasonComplete;
                            break;
                        case 'high':
                            matchesProgress = progress >= 75 && progress < 100;
                            break;
                        case 'medium':
                            matchesProgress = progress >= 25 && progress < 75;
                            break;
                        case 'low':
                            matchesProgress = progress < 25;  // includes 0%
                            break;
                        case 'date-high':
                            matchesProgress = dateRangeProgress >= 75;
                            break;
                        case 'date-low':
                            matchesProgress = dateRangeProgress < 25;  // includes 0%
                            break;
                        case 'has-episodes':
                            matchesProgress = hasEpisodes;
                            break;
                        default:
                            matchesProgress = true;
                    }
                }

                wrapper.style.display = (matchesSearch && matchesProgress) ? 'block' : 'none';
            });
        }

        // Attach event listeners
        document.getElementById('titleSearch').addEventListener('input', applyFilters);
        document.getElementById('progressFilter').addEventListener('change', applyFilters);

        // Clear filters
        document.getElementById('clearFilters').addEventListener('click', function() {
            document.getElementById('titleSearch').value = '';
            document.getElementById('progressFilter').value = 'all';
            const jumpSelect = document.getElementById('jumpToShow');
            if (jumpSelect) jumpSelect.value = '#all';
            applyFilters();
        });

        document.addEventListener('DOMContentLoaded', function() {
            const savedTheme = localStorage.getItem('sonarr-theme') || '{{ config.html_theme }}';
            document.body.classList.add('theme-' + savedTheme);
            updateThemeButton(savedTheme);

            document.getElementById('themeToggle').addEventListener('click', function() {
                const isDark = document.body.classList.contains('theme-dark');
                document.body.classList.remove('theme-dark', 'theme-light');
                const newTheme = isDark ? 'light' : 'dark';
                document.body.classList.add('theme-' + newTheme);
                localStorage.setItem('sonarr-theme', newTheme);
                updateThemeButton(newTheme);
            });

            setupExpandButtons();
            setupMouseLeaveHandlers();
        });
    </script>
</body>
</html>